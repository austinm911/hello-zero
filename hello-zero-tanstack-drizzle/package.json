{
	"name": "zero-tanstack-drizzle",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun run scripts/dev.ts",
		"build": "vite build && tsc --noEmit",
		"check": "biome check --write",
		"clean": "rm -rf node_modules bun.lock",
		"types": "tsc --noEmit",
		"clean:docker": "docker volume rm -f zero_tanstack_drizzle_pgdata",
		"dev:db-down": "docker compose -f ./docker/docker-compose.yml down",
		"dev:db-up": "docker compose -f ./docker/docker-compose.yml up",
		"dev:ui": "vite",
		"dev:zero-cache": "zero-cache-dev --port 4949 -p ./src/db/schema/zero.ts",
		"generate": "drizzle-kit generate",
		"migrate": "drizzle-kit migrate",
		"push": "drizzle-kit push",
		"seed": "bun run src/db/seed.ts",
		"skott": "bunx skott",
		"start": "vite start",
		"studio": "drizzle-kit studio",
		"update-packages": "bunx taze -I --recursive"
	},
	"dependencies": {
		"@hono/node-server": "^1.13.7",
		"@radix-ui/react-accordion": "^1.2.2",
		"@radix-ui/react-alert-dialog": "^1.1.5",
		"@radix-ui/react-checkbox": "^1.1.3",
		"@radix-ui/react-collapsible": "^1.1.2",
		"@radix-ui/react-dialog": "^1.1.5",
		"@radix-ui/react-dropdown-menu": "^2.1.5",
		"@radix-ui/react-label": "^2.1.1",
		"@radix-ui/react-popover": "^1.1.5",
		"@radix-ui/react-select": "^2.1.5",
		"@radix-ui/react-separator": "^1.1.1",
		"@radix-ui/react-slider": "^1.2.2",
		"@radix-ui/react-slot": "^1.1.1",
		"@radix-ui/react-switch": "^1.1.2",
		"@radix-ui/react-tabs": "^1.1.2",
		"@radix-ui/react-toast": "^1.2.5",
		"@radix-ui/react-tooltip": "^1.1.7",
		"@rocicorp/zero": "^0.12.2025012501",
		"@t3-oss/env-core": "^0.12.0",
		"@tanstack/react-router": "^1.97.23",
		"@tanstack/react-router-with-query": "^1.97.23",
		"@tanstack/zod-adapter": "^1.97.23",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.38.4",
		"drizzle-zero": "^0.3.0",
		"drizzle-zod": "^0.6.1",
		"framer-motion": "^12.0.5",
		"hono": "^4.6.19",
		"jose": "^5.9.6",
		"js-cookie": "^3.0.5",
		"lucide-react": "^0.474.0",
		"nanoid": "^5.0.9",
		"pg": "^8.13.1",
		"react": "^19.0.0",
		"react-day-picker": "^9.5.0",
		"react-dom": "^19.0.0",
		"react-dropzone": "^14.3.5",
		"react-hook-form": "^7.54.2",
		"react-number-format": "^5.4.3",
		"sonner": "^1.7.2",
		"tailwind-merge": "^2.6.0",
		"tailwindcss-animate": "^1.0.7",
		"uuidv7-js": "^1.1.4",
		"vaul": "^1.1.2",
		"vite": "^6.0.11",
		"ws": "^8.18.0",
		"zod": "^3.24.1",
		"zod-form-renderer": "^1.2.1"
	},
	"devDependencies": {
		"@biomejs/biome": "latest",
		"@faker-js/faker": "^9.4.0",
		"@tanstack/react-query-devtools": "^5.64.2",
		"@tanstack/router-devtools": "^1.97.23",
		"@tanstack/router-plugin": "^1.97.23",
		"@types/bun": "^1.2.0",
		"@types/js-cookie": "^3.0.6",
		"@types/pg": "^8.11.11",
		"@types/react": "^19.0.8",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react": "^4.3.4",
		"autoprefixer": "^10.4.20",
		"concurrently": "~9.1.2",
		"drizzle-kit": "^0.30.2",
		"postcss": "^8.5.1",
		"tailwindcss": "^3.4.17",
		"ts-essentials": "^10.0.4",
		"typescript": "5.7.3",
		"vite-tsconfig-paths": "^5.1.4"
	},
	"packageManager": "bun@1.2.0",
	"trustedDependencies": ["@biomejs/biome", "@rocicorp/zero-sqlite3", "esbuild"]
}
